{
  "name": "Aneesh Portfolio",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22",
  "postCreateCommand": "corepack pnpm --version",
  "customizations": {
    "vscode": {
      "extensions": [
        "ownable.ownable"
      ]
    }
  },
  "mounts": [
    "source=pnpm-store,target=/home/vscode/.local/share/pnpm,type=volume"
  ],
  "remoteUser": "vscode",
  "forwardPorts": [
    1313
  ],
  "portsAttributes": {
    "1313": {
      "label": "Portfolio Preview"
    }
  }
}
